# WhatsApp number in E.164 digits only (no +)
VITE_WHATSAPP_E164=972525424242

# Canonical site URL for Open Graph / JSON-LD (no trailing slash).
# In production builds, defaults to https://guynimni.co.il when unset.
# VITE_SITE_URL=https://staging.example.co.il

# Accessibility statement (optional — defaults are set in src/config/site.js)
# VITE_ACCESSIBILITY_EMAIL=
# VITE_ACCESSIBILITY_PHONE=
